# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*$py.class
*.so
*.egg-info/
dist/
.eggs/

# 虚拟环境
venv/
.venv/
env/

# 敏感配置（包含 API Key）
.env
*.env

# 个人数据库（私人数据，不上传）
shouyi_personal.json

# ChromaDB 向量数据库（含私人数据，不上传；首次启动自动构建）
chroma_db/

# 日志
logs/
*.log

# 临时文件
*.tmp
*.bak
request_debug.jsonl

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# 模型缓存（大文件，不上传）
models_cache/

# 安装包
*.pkg
*.dmg
*.zip

# WebUI 密钥
.webui_secret_key

# articles 子目录有独立的 Git 仓库，不纳入外层管理
app/articles/

# 运行时数据扩展匹配
app/chroma_db/
app/.venv/
app/logs/
app/__pycache__/
app/*.pyc
app/request_debug*
app/shouyi_personal.json

# 构建产物（由 build_mac.py / build_win.py 生成，不提交）
build/
build_win/
build_mac/

# 根目录旧版副本（防止误提交）
/config.py
/knowledge.py
/models.py
/prompts.py
/server.py
/share_routes.py
/start.py
/stream.py
/tools.py
/auto_teach.py
/version.py
/requirements.txt
/templates/
/articles/
