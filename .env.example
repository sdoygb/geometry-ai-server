# Geometry AI Server 配置文件
# 复制此文件到 .env 并填入你的 API Key

# === DeepSeek 配置（推荐） ===
GAI_API_KEY=在此填入你的DeepSeek API Key
GAI_BASE_URL=https://api.deepseek.com/v1
GAI_MODEL=deepseek-v4-pro
GAI_MODEL_LITE=deepseek-v4-flash
GAI_MODEL_VISION=deepseek-v4-flash
GAI_EMBEDDING_MODEL=deepseek-v4-flash

# === KIMI 配置（备用，注释掉） ===
# GAI_API_KEY=在此填入你的KIMI API Key
# GAI_BASE_URL=https://api.moonshot.cn/v1
# GAI_MODEL=kimi-k2.7-code
# GAI_MODEL_LITE=kimi-k2.7
# GAI_MODEL_VISION=kimi-k2.6

# === SiliconFlow Embedding ===
SILICONFLOW_API_KEY=在此填入你的SiliconFlow API Key
GAI_EMBEDDING_MODE=siliconflow
GAI_LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# === MySQL 配置（Docker部署用，不硬编码到docker-compose.yml） ===
MYSQL_ADMIN_PASS=在此填入你的MySQL管理员密码
MYSQL_PUBLIC_PASS=在此填入你的MySQL公开用户密码
