# Geometry AI Server 配置文件
# 复制此文件到 ~/AI/.env 并填入你的 API Key

# === DeepSeek 配置（推荐，便宜） ===
KIMI_API_KEY=在此填入你的DeepSeek API Key
KIMI_BASE_URL=https://api.deepseek.com/v1
KIMI_MODEL=deepseek-v4-flash
KIMI_MODEL_LITE=deepseek-v4-flash
KIMI_MODEL_VISION=deepseek-v4-flash
KIMI_EMBEDDING_MODEL=deepseek-v4-flash

# === KIMI 配置（备用，贵） ===
# KIMI_API_KEY=在此填入你的KIMI API Key
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.7-code
# KIMI_MODEL_LITE=kimi-k2.7
# KIMI_MODEL_VISION=kimi-k2.6
# KIMI_EMBEDDING_MODEL=moonshot-embedding-v1
